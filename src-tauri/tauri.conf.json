{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkMemory",
  "version": "2.2.0",
  "identifier": "com.workmemory.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "WorkMemory",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true,
        "visible": true
      },
      {
        "label": "mascot",
        "title": "Mascot",
        "width": 80,
        "height": 80,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": true,
        "x": 1820,
        "y": 980
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://tauri.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/WorkMemory/**", "$APPLOCALDATA/WorkMemory/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "publisher": "WorkMemory",
    "category": "Productivity",
    "shortDescription": "桌面工作记忆助手",
    "longDescription": "WorkMemory 是一个住在你桌面上的工作记忆助手——它默默记住你做过的一切，在你需要的时候帮你回忆、整理、输出。",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "headerImage": null,
        "sidebarImage": null,
        "installerIcon": null
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {}
}
